CORE_BASE_URL=http://127.0.0.1:8000
NODE_NAME=email-node-dev
NODE_TYPE=email-node
NODE_SOFTWARE_VERSION=0.1.0
NODE_NONCE=replace-with-unique-node-nonce
RUNTIME_DIR=runtime
ONBOARDING_PROTOCOL_VERSION=1.0
ONBOARDING_POLL_INTERVAL_SECONDS=2
MQTT_HEARTBEAT_SECONDS=30
PROVIDERS__GMAIL__ENABLED=false
PROVIDERS__SMTP__ENABLED=false
PROVIDERS__IMAP__ENABLED=false
