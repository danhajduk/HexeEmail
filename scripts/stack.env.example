# Copy this file to scripts/stack.env and adjust commands for your machine.

# Base directory where commands should run.
APP_DIR=/home/dan/Projects/HexeEmail

# Backend process command.
# Example: BACKEND_CMD="API_PORT=9003 /home/dan/Projects/HexeEmail/.venv/bin/python -m uvicorn main:create_app --factory --app-dir src --host 0.0.0.0 --port 9003"
BACKEND_CMD="API_PORT=9003 ./scripts/dev.sh"

# Frontend process command.
# Example: FRONTEND_CMD="cd frontend && API_PROXY_TARGET=http://127.0.0.1:9003 npm run dev -- --host 0.0.0.0 --port 8083"
FRONTEND_CMD="API_PROXY_TARGET=http://127.0.0.1:9003 ./scripts/ui-dev.sh"
